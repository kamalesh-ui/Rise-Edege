{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/chat", "destination": "https://rise-edege.onrender.com/api/chat" },
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "env": {
    "VITE_API_URL": "https://rise-edege.onrender.com"
  }
}